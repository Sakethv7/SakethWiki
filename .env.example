# Copy this to .env and fill in your values

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LLM routing
# Recommended profile:
# - Fast UX/default route: Gemini 2.5 Flash through OpenAI-compatible API
# - Integrity route: Anthropic Claude for source-of-truth judgment tasks
LLM_PROVIDER=openai_compat

# Integrity task overrides. These tasks can affect durable vault state or review
# quality, so they should favor judgment over speed/cost.
LLM_PROVIDER_LINT_SCAN=anthropic
LLM_PROVIDER_LINT_JSON_FIX=anthropic
LLM_PROVIDER_CONSOLIDATE_PAGES=anthropic
LLM_PROVIDER_KNOWLEDGE_GAPS=anthropic
LLM_PROVIDER_EVOLUTION_CLASSIFY=anthropic

# Per-task overrides (optional), examples:
# LLM_PROVIDER_INGEST_EXTRACT=anthropic
# LLM_PROVIDER_CHAT_ANSWER=ollama

# Interview mode — verification + grading (default: ollama with qwen3:14b)
# Run: ollama pull qwen3:14b
LLM_PROVIDER_INTERVIEW_VERIFY=ollama
LLM_MODEL_INTERVIEW_VERIFY=qwen3:14b
LLM_PROVIDER_INTERVIEW_GRADE=ollama
LLM_MODEL_INTERVIEW_GRADE=qwen3:14b

# Per-task model overrides (optional), examples:
# LLM_MODEL_INGEST_EXTRACT=qwen-vl-plus
# LLM_MODEL_CHAT_ANSWER=qwen-plus

# Contract fallback guardrail:
# If enabled (globally or per-task), invalid output/contracts are retried on Anthropic.
LLM_FALLBACK_TO_ANTHROPIC=
# Per-task override examples:
# LLM_FALLBACK_INGEST_EXTRACT=true
# LLM_FALLBACK_CHAT_ANSWER=false
# Optional Anthropic fallback model override per task:
# LLM_FALLBACK_MODEL_LINT_SCAN=claude-sonnet-4-6

# Anthropic defaults used when provider=anthropic and no task model is set
ANTHROPIC_MODEL_TEXT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6

# Qwen (DashScope OpenAI-compatible endpoint)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_TEXT=qwen-plus
QWEN_MODEL_VISION=qwen-vl-plus

# Ollama (local OpenAI-compatible endpoint)
# Example: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL_TEXT=qwen2.5:7b
OLLAMA_MODEL_VISION=qwen2.5vl:7b

# Gemma/OpenAI-compatible provider config
# Set GEMMA_OPENAI_BASE_URL to your provider's OpenAI-compatible base URL.
GEMMA_API_KEY=
GEMMA_OPENAI_BASE_URL=
GEMMA_MODEL_TEXT=gemma-3-27b-it
GEMMA_MODEL_VISION=gemma-3-27b-it

# Generic OpenAI-compatible provider fallback
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL_TEXT=gemini-2.5-flash
OPENAI_COMPAT_MODEL_VISION=gemini-2.5-flash

# OpenAI (native) for embeddings / reranking orchestration
OPENAI_API_KEY=
# Persistent memory index:
# - SakethWiki always builds a SQLite memory index at _wiki/meta/memory.db
# - Set EMBED_ENABLED=true to export chunks to an embedding provider for semantic retrieval
# Embeddings config
EMBED_ENABLED=false
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_BATCH_SIZE=64

# Path to your Obsidian vault (must be in home dir, not ~/Documents, to avoid macOS TCC restrictions)
VAULT_PATH=/Users/yourname/SakethVault

# Optional: X/Twitter API credentials (only needed if Twitter ingestion is used)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
